# LionFrame OIDC Provider（:3000 で稼働している前提）
LIONFRAME_ISSUER=http://localhost:3000/api/oidc
LIONFRAME_CLIENT_ID=replace-with-registered-client-id
LIONFRAME_CLIENT_SECRET=replace-with-registered-client-secret

# RP（この opencode-demo）の公開 URL。redirect_uri の組み立てに使用
NEXTAUTH_URL=http://localhost:3001

# oidc_session JWT（HS256）署名鍵。32 文字以上のランダム文字列。
# 生成コマンド: openssl rand -hex 32
SESSION_SECRET=replace-with-32byte-random-hex
